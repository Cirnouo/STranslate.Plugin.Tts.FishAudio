<UserControl
    x:Class="STranslate.Plugin.Tts.FishAudio.View.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:plugin="clr-namespace:STranslate.Plugin;assembly=STranslate.Plugin"
    xmlns:conv="clr-namespace:STranslate.Plugin.Tts.FishAudio.Converter"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:STranslate.Plugin.Tts.FishAudio.ViewModel"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="1400"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:TaskCountConverter x:Key="TaskCountConverter" />
        <conv:ProgressToDashOffsetConverter x:Key="ProgressToDashOffsetConverter" />
        <BooleanToVisibilityConverter x:Key="BtvConverter" />
    </UserControl.Resources>

    <ikw:SimpleStackPanel Spacing="12">

        <!-- ════════ 账户 ════════ -->

        <TextBlock
            Margin="0,4,0,0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Group_Account}" />

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_AccountInfo}">
            <ui:SettingsCard.Description>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Credit}" VerticalAlignment="Center"
                               Visibility="{Binding UserCredit, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />
                    <TextBlock Margin="4,0,0,0" Text="{Binding UserCredit}" VerticalAlignment="Center"
                               Visibility="{Binding UserCredit, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />
                    <TextBlock Text=" $" VerticalAlignment="Center"
                               Visibility="{Binding UserCredit, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />
                </StackPanel>
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Person_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button
                    Command="{Binding RefreshCreditCommand}"
                    Content="{DynamicResource STranslate_Plugin_Tts_FishAudio_Refresh}" />
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0"
                            Visibility="{Binding LatencyText, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="&#xEC05;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               VerticalAlignment="Center" Foreground="{Binding LatencyBrush}" Margin="0,0,4,0" />
                    <TextBlock VerticalAlignment="Center" FontSize="12"
                               Foreground="{Binding LatencyBrush}" Text="{Binding LatencyText}" />
                </StackPanel>
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Url}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Globe_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="https://api.fish.audio" />
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_ApiKey}">
            <ui:SettingsCard.Description>
                <StackPanel Orientation="Horizontal">
                    <ui:HyperlinkButton
                        Content="fish.audio"
                        NavigateUri="https://fish.audio/app/api-keys" />
                    <StackPanel Margin="8,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ApiKeyStatusKind}" Value="{x:Static vm:ApiKeyStatusKind.None}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE946;" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ApiKeyStatusKind}" Value="{x:Static vm:ApiKeyStatusKind.Success}">
                                            <Setter Property="Text" Value="&#xE73E;" />
                                            <Setter Property="Foreground" Value="#FF4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ApiKeyStatusKind}" Value="{x:Static vm:ApiKeyStatusKind.Error}">
                                            <Setter Property="Text" Value="&#xEA39;" />
                                            <Setter Property="Foreground" Value="#FFE57373" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Setter Property="Text" Value="{DynamicResource STranslate_Plugin_Tts_FishAudio_ApiKey_Waiting}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ApiKeyStatusKind}" Value="{x:Static vm:ApiKeyStatusKind.Success}">
                                            <Setter Property="Foreground" Value="#FF4CAF50" />
                                            <Setter Property="Text" Value="{DynamicResource STranslate_Plugin_Tts_FishAudio_ApiKey_Applied}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ApiKeyStatusKind}" Value="{x:Static vm:ApiKeyStatusKind.Error}">
                                            <Setter Property="Foreground" Value="#FFE57373" />
                                            <Setter Property="Text" Value="{Binding ApiKeyStatusText}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Key_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <DockPanel>
                <Button DockPanel.Dock="Right" Margin="4,0,0,0" Padding="6"
                        Background="Transparent" BorderThickness="0"
                        Command="{Binding ConfirmApiKeyCommand}"
                        ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_Confirm}">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="4,0,0,0" Padding="6"
                        Background="Transparent" BorderThickness="0"
                        Command="{Binding PasteApiKeyCommand}"
                        ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_Paste}">
                    <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                </Button>
                <PasswordBox
                    MinWidth="230"
                    plugin:PasswordBoxAssistant.Attach="True"
                    plugin:PasswordBoxAssistant.Password="{Binding ApiKey}"
                    ui:ControlHelper.PlaceholderText="{DynamicResource STranslate_Plugin_Tts_FishAudio_ApiKey_Placeholder}">
                    <PasswordBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmApiKeyCommand}" />
                    </PasswordBox.InputBindings>
                </PasswordBox>
            </DockPanel>
        </ui:SettingsCard>

        <!-- ════════ 声音 ════════ -->

        <TextBlock
            Margin="0,8,0,0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Group_Voice}" />

        <!-- 展示区：已选声音 -->
        <Border
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <!-- 试听按钮（带进度环） -->
                    <Grid Width="36" Height="36" Margin="0,0,4,0"
                          Visibility="{Binding CachedVoiceSampleUrl, Converter={StaticResource StringToVisibilityConverter}}">
                        <Ellipse x:Name="DisplayRestBorder" StrokeThickness="1"
                                 Stroke="{DynamicResource ControlStrokeColorDefaultBrush}" Fill="Transparent">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDisplayVoicePreviewing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <Ellipse x:Name="DisplayTrack" StrokeThickness="1.5"
                                 Stroke="#1FFFFFFF" Fill="Transparent"
                                 Visibility="{Binding IsDisplayVoicePreviewing, Converter={StaticResource BtvConverter}}" />
                        <Ellipse StrokeThickness="1.5" Stroke="White" Fill="Transparent"
                                 StrokeDashArray="72.26 72.26"
                                 StrokeDashOffset="{Binding PreviewProgress, Converter={StaticResource ProgressToDashOffsetConverter}}"
                                 StrokeDashCap="Round"
                                 RenderTransformOrigin="0.5,0.5"
                                 Visibility="{Binding IsDisplayVoicePreviewing, Converter={StaticResource BtvConverter}}">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Button Background="Transparent" BorderThickness="0" Padding="0"
                                Width="36" Height="36"
                                Command="{Binding ToggleDisplayPreviewCommand}"
                                ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_PlaySample}">
                            <Grid>
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE768;" />
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDisplayVoicePreviewing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Width="10" Height="10" CornerRadius="1" Background="White"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding IsDisplayVoicePreviewing, Converter={StaticResource BtvConverter}}" />
                            </Grid>
                        </Button>
                    </Grid>
                    <Button
                        Padding="8,4"
                        Command="{Binding ClearVoiceCommand}"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_ClearVoice}"
                        Visibility="{Binding CachedVoiceId, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>
                <Ellipse DockPanel.Dock="Left" Width="48" Height="48" Margin="0,0,12,0" VerticalAlignment="Center"
                         Visibility="{Binding CachedVoiceCoverUrl, Converter={StaticResource StringToVisibilityConverter}}">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding CachedVoiceCoverUrl}" Stretch="UniformToFill" />
                    </Ellipse.Fill>
                </Ellipse>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock FontWeight="Medium" FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding CachedVoiceTitle}" />
                                <Setter Property="Visibility" Value="{Binding CachedVoiceTitle, Converter={StaticResource StringToVisibilityConverter}}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CachedVoiceId}" Value="{x:Null}">
                                        <Setter Property="Text" Value="{DynamicResource STranslate_Plugin_Tts_FishAudio_RandomVoice}" />
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CachedVoiceDescription}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="12" TextWrapping="Wrap" TextTrimming="WordEllipsis" MaxHeight="36"
                               Visibility="{Binding CachedVoiceDescription, Converter={StaticResource StringToVisibilityConverter}}" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="{Binding CachedVoiceAuthor}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11"
                                   Visibility="{Binding CachedVoiceAuthor, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Margin="12,0,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11"
                                   Visibility="{Binding CachedVoiceId, Converter={StaticResource StringToVisibilityConverter}}">
                            <Run Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Popularity}" />
                            <Run Text="{Binding CachedVoiceTaskCount, Converter={StaticResource TaskCountConverter}, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 选项卡栏 -->
        <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Background="Transparent" BorderThickness="0" Padding="8,6" Margin="0,0,2,0"
                        Command="{Binding SwitchToSearchCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Tab_Search}"
                                   VerticalAlignment="Center" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearchMode}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <Setter Property="FontWeight" Value="Medium" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
                <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                        Command="{Binding SwitchToByIdCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Tab_ById}"
                                   VerticalAlignment="Center" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearchMode}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <Setter Property="FontWeight" Value="Medium" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Grid MinHeight="36">
            <!-- 搜索面板 -->
            <ikw:SimpleStackPanel Spacing="8"
                Visibility="{Binding IsSearchMode, Converter={StaticResource BtvConverter}}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="6"
                            Background="Transparent" BorderThickness="0"
                            Command="{Binding SearchVoicesCommand}"
                            ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_Search}">
                        <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Search_24_Regular}" FontSize="16" />
                    </Button>
                    <TextBox
                        ui:ControlHelper.PlaceholderText="{DynamicResource STranslate_Plugin_Tts_FishAudio_SearchPlaceholder}"
                        Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchVoicesCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>
                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontFamily="Consolas"
                           Visibility="{Binding HasSearched, Converter={StaticResource BtvConverter}}">
                    <Run Text="{Binding SearchResultCount, Mode=OneWay}" />
                    <Run Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_ResultCount}" />
                </TextBlock>
                <ItemsControl ItemsSource="{Binding SearchResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="8"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="6">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Grid Width="36" Height="36" Margin="0,0,4,0"
                                              Visibility="{Binding SampleAudioUrl, Converter={StaticResource StringToVisibilityConverter}}">
                                            <Ellipse x:Name="SRestBorder" StrokeThickness="1"
                                                     Stroke="{DynamicResource ControlStrokeColorDefaultBrush}" Fill="Transparent" />
                                            <Ellipse x:Name="STrack" StrokeThickness="1.5"
                                                     Stroke="#1FFFFFFF" Fill="Transparent" Visibility="Collapsed" />
                                            <Ellipse x:Name="SArc" StrokeThickness="1.5" Stroke="White" Fill="Transparent"
                                                     StrokeDashArray="72.26 72.26"
                                                     StrokeDashOffset="{Binding PreviewProgress, Converter={StaticResource ProgressToDashOffsetConverter}}"
                                                     StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                                                <Ellipse.RenderTransform>
                                                    <RotateTransform Angle="-90"/>
                                                </Ellipse.RenderTransform>
                                            </Ellipse>
                                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                    Width="36" Height="36"
                                                    Command="{Binding DataContext.ToggleSearchItemPreviewCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_PlaySample}">
                                                <Grid>
                                                    <TextBlock x:Name="SIcon" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" Text="&#xE768;" />
                                                    <Border x:Name="SStopIcon" Width="9" Height="9" CornerRadius="1" Background="White"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
                                                </Grid>
                                            </Button>
                                        </Grid>
                                        <Button MinHeight="28" Padding="8,4" VerticalContentAlignment="Center"
                                                Command="{Binding DataContext.SelectVoiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{DynamicResource STranslate_Plugin_Tts_FishAudio_Select}" />
                                    </StackPanel>
                                    <Ellipse DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding CoverUrl}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Title}" FontWeight="Medium" TextTrimming="CharacterEllipsis" MaxWidth="280" />
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11"
                                                   TextTrimming="WordEllipsis" TextWrapping="Wrap" MaxHeight="30" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding AuthorName}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock Margin="12,0,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11">
                                                <Run Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Popularity}" />
                                                <Run Text="{Binding TaskCount, Converter={StaticResource TaskCountConverter}, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsBeingPreviewed}" Value="True">
                                    <Setter TargetName="SRestBorder" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="STrack" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="SArc" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="SIcon" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="SStopIcon" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Grid Visibility="{Binding ShowPagination, Converter={StaticResource BtvConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" HorizontalAlignment="Left" Command="{Binding PrevPageCommand}" Padding="8,4"
                            Visibility="{Binding ShowPrevPage, Converter={StaticResource BtvConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Prev}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBox x:Name="PageInputBox" Width="40" TextAlignment="Center" FontFamily="Consolas"
                                 FontSize="12" Padding="4,2" VerticalContentAlignment="Center"
                                 Text="{Binding PageInput, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="PageInputBox_PreviewTextInput"
                                 LostFocus="PageInputBox_LostFocus">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding CommitPageInputCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock VerticalAlignment="Center" Margin="4,0,0,0" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_PageOf}" />
                            <Run Text="{Binding SearchTotalPages, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="2" HorizontalAlignment="Right" Command="{Binding NextPageCommand}" Padding="8,4"
                            Visibility="{Binding ShowNextPage, Converter={StaticResource BtvConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Next}" VerticalAlignment="Center" />
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </Button>
                </Grid>
            </ikw:SimpleStackPanel>

            <!-- 通过 ID 面板 -->
            <ikw:SimpleStackPanel Spacing="8">
                <ikw:SimpleStackPanel.Style>
                    <Style TargetType="ikw:SimpleStackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearchMode}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ikw:SimpleStackPanel.Style>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Margin="4,0,0,0" Padding="6"
                            Background="Transparent" BorderThickness="0"
                            Command="{Binding SubmitVoiceIdCommand}"
                            ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_SetVoice}">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <Button DockPanel.Dock="Right" Margin="4,0,0,0" Padding="6"
                            Background="Transparent" BorderThickness="0"
                            Command="{Binding PasteVoiceIdCommand}"
                            ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_Paste}">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <TextBox ui:ControlHelper.PlaceholderText="{DynamicResource STranslate_Plugin_Tts_FishAudio_VoiceId_Placeholder}"
                             Text="{Binding VoiceIdInput, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SubmitVoiceIdCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>
                <TextBlock FontSize="12" Foreground="#FFE57373" Text="{Binding VoiceIdError}" TextWrapping="Wrap"
                           Visibility="{Binding VoiceIdError, Converter={StaticResource StringToVisibilityConverter}}" />
            </ikw:SimpleStackPanel>
        </Grid>

        <!-- ════════ 模型 ════════ -->

        <TextBlock Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold"
                   Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Group_Model}" />

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Engine}">
            <ui:SettingsCard.Description>
                <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Engine_Description}" />
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.BrainCircuit_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox MinWidth="120" ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" />
        </ui:SettingsCard>

        <!-- ════════ 音频输出 ════════ -->

        <TextBlock Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold"
                   Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Group_AudioOutput}" />

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Mp3Bitrate}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.MusicNote2_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox MinWidth="100" ItemsSource="{Binding Mp3Bitrates}" SelectedItem="{Binding Mp3Bitrate}" />
        </ui:SettingsCard>

        <!-- ════════ 韵律 ════════ -->

        <TextBlock Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold"
                   Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Group_Prosody}" />

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Speed}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.TopSpeed_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider Width="180" IsSnapToTickEnabled="True" Maximum="2.0" Minimum="0.5" TickFrequency="0.05" Value="{Binding Speed}" />
                <TextBlock MinWidth="36" Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding Speed, StringFormat='{}{0:F2}'}" />
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Volume}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Speaker2_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider Width="180" IsSnapToTickEnabled="True" Maximum="10" Minimum="-10" TickFrequency="0.1" Value="{Binding Volume}" />
                <TextBlock MinWidth="48" Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding Volume, StringFormat='{}{0:F1} dB'}" />
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard
            Visibility="{Binding ShowNormalizeLoudness, Converter={StaticResource BtvConverter}}"
            Description="{DynamicResource STranslate_Plugin_Tts_FishAudio_NormalizeLoudness_Description}"
            Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_NormalizeLoudness}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.MusicNote2_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:ToggleSwitch IsOn="{Binding NormalizeLoudness}" />
        </ui:SettingsCard>

        <!-- ════════ 生成参数 ════════ -->

        <TextBlock Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold"
                   Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Group_Generation}" />

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Temperature}">
            <ui:SettingsCard.Description>
                <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Temperature_Description}" />
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Sparkle_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider Width="180" IsSnapToTickEnabled="True" Maximum="1.0" Minimum="0" TickFrequency="0.05" Value="{Binding Temperature}" />
                <TextBlock MinWidth="36" Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding Temperature, StringFormat='{}{0:F2}'}" />
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_TopP}">
            <ui:SettingsCard.Description>
                <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_TopP_Description}" />
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Diversity_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider Width="180" IsSnapToTickEnabled="True" Maximum="1.0" Minimum="0" TickFrequency="0.05" Value="{Binding TopP}" />
                <TextBlock MinWidth="36" Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding TopP, StringFormat='{}{0:F2}'}" />
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Latency}">
            <ui:SettingsCard.Description>
                <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Latency_Description}" />
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Timer_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox MinWidth="120" ItemsSource="{Binding Latencies}" SelectedItem="{Binding SelectedLatency}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="normal">
                                            <Setter Property="Text" Value="{DynamicResource STranslate_Plugin_Tts_FishAudio_Latency_Normal}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="balanced">
                                            <Setter Property="Text" Value="{DynamicResource STranslate_Plugin_Tts_FishAudio_Latency_Balanced}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="low">
                                            <Setter Property="Text" Value="{DynamicResource STranslate_Plugin_Tts_FishAudio_Latency_Low}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </ui:SettingsCard>

        <ui:SettingsCard
            Description="{DynamicResource STranslate_Plugin_Tts_FishAudio_Normalize_Description}"
            Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Normalize}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.TextEditStyle_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:ToggleSwitch IsOn="{Binding Normalize}" />
        </ui:SettingsCard>

        <ui:SettingsCard
            Description="{DynamicResource STranslate_Plugin_Tts_FishAudio_ConditionOnPreviousChunks_Description}"
            Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_ConditionOnPreviousChunks}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.LinkMultiple_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:ToggleSwitch IsOn="{Binding ConditionOnPreviousChunks}" />
        </ui:SettingsCard>

        <!-- ════════ 其他 ════════ -->

        <TextBlock Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold"
                   Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_Group_Misc}" />

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Cache}">
            <ui:SettingsCard.Description>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_FishAudio_CacheUsage}" />
                    <TextBlock Margin="4,0,0,0" Text="{Binding CoverImageCacheSizeText}" />
                </StackPanel>
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Image_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <Button Padding="6" Background="Transparent" BorderThickness="0"
                    Command="{Binding ClearCoverImageCacheCommand}"
                    ToolTip="{DynamicResource STranslate_Plugin_Tts_FishAudio_ClearCache}">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
            </Button>
        </ui:SettingsCard>

        <ui:SettingsCard
            Description="{DynamicResource STranslate_Plugin_Tts_FishAudio_Support_Description}"
            Header="{DynamicResource STranslate_Plugin_Tts_FishAudio_Support}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.PersonSupport_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:HyperlinkButton Content="fish.audio" NavigateUri="https://fish.audio" />
        </ui:SettingsCard>

    </ikw:SimpleStackPanel>
</UserControl>
