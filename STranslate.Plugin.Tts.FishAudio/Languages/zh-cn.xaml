<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- 分组标题 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Group_Account">账户</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Group_Model">模型</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Group_Engine">语音合成引擎</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Group_Prosody">韵律</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Group_AudioOutput">音频输出</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Group_Generation">生成参数</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Group_Misc">其他</sys:String>

    <!-- 账户 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_AccountInfo">账户信息</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Credit">余额:</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Refresh">刷新</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Url">API 地址</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_ApiKey">API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_ApiKey_Placeholder">输入 Fish Audio API Key</sys:String>

    <!-- 模型 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_CurrentModel">当前模型</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_ReferenceId">模型 ID</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_ReferenceId_Placeholder">输入模型 ID 或通过搜索选择</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_SearchModel">搜索模型</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Search">搜索</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_SearchPlaceholder">输入模型名称搜索...</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Select">选择</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_PlaySample">试听</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_ClearModel">清除</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_UsageCount">次使用</sys:String>

    <!-- 引擎 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Model">合成引擎</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Model_Description">S2-Pro 推荐，支持 80+ 种语言和情绪标记</sys:String>

    <!-- 韵律 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Speed">语速</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Volume">音量</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Volume_Description">音量偏移 (dB)，正值增大、负值减小</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_NormalizeLoudness">响度归一化</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_NormalizeLoudness_Description">仅 S2-Pro 引擎支持</sys:String>

    <!-- 音频输出 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Format">输出格式</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Mp3Bitrate">MP3 比特率 (kbps)</sys:String>

    <!-- 生成参数 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Temperature">表现力</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Temperature_Description">越高越多样化</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_TopP">多样性</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_TopP_Description">核采样多样性控制</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Latency">延迟模式</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Latency_Description">延迟与质量的权衡</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Latency_Normal">质量优先</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Latency_Balanced">平衡</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Latency_Low">低延迟优先</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Normalize">文本规范化</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Normalize_Description">自动将数字转换为文字等</sys:String>

    <!-- 其他 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Support">支持</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Support_Description">Fish Audio 官网</sys:String>

    <!-- 运行时消息 -->
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_ApiKey_Empty">请先设置 API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Text_Empty">文本为空</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_Model_NotFound">未找到该模型</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_FishAudio_RandomModel">随机模型</sys:String>

</ResourceDictionary>
